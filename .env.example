PORT=3000
HOST_URL=http://localhost:3000
NODE_ENV=development

# HTTPS toggle
HTTPS_ENABLED=false
SSL_KEY_PATH=./certs/localhost-key.pem
SSL_CERT_PATH=./certs/localhost.pem

# CORS configuration
# Comma-separated values
CORS_ORIGINS=
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization
CORS_CREDENTIALS=true

# MCP / AI configuration
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY   — required. For OpenAI use your sk- key. For compatible
#                    providers (NVIDIA NIM, Groq, Ollama, LM Studio, vLLM,
#                    Together AI, etc.) use the key they provide.
# OPENAI_BASE_URL  — optional. Leave blank to use OpenAI directly.
#                    Set to the provider's OpenAI-compatible endpoint.
# OPENAI_MODEL     — optional. Defaults to gpt-4o-mini when not set.
#                    Set to the exact model ID your provider expects.
#
# Example — NVIDIA NIM (free tier at build.nvidia.com):
#   OPENAI_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
#   OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
#   OPENAI_MODEL=moonshotai/kimi-k2-instruct
#
# Example — Groq (free tier):
#   OPENAI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.3-70b-versatile
#
# Example — Ollama (local, no key needed):
#   OPENAI_API_KEY=ollama
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=llama3.1
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=moonshotai/kimi-k2-instruct
MCP_DEBUG_LOGGING=false
